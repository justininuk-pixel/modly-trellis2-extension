{
  "id": "trellis-2",
  "name": "TRELLIS.2",
  "type": "model",
  "version": "1.0.1",
  "author": "Lightning Pixel (fixed)",
  "source": "https://github.com/microsoft/TRELLIS.2",
  "description": "High-fidelity image-to-3D with PBR textures via O-Voxel structured latents. Generates GLB with full PBR materials.",
  
  "generator_class": "Trellis2Generator",

  "tags": [
    "image-to-3d",
    "high-quality",
    "pbr",
    "diffusion"
  ],

  "nodes": [
    {
      "id": "trellis-2-node",
      "name": "TRELLIS.2 Generator",
      "input": "image",
      "output": "file",

      "description": "Generate a textured 3D model (GLB) from a single image using TRELLIS.2",

      "params_schema": [
        {
          "id": "pipeline_type",
          "label": "Resolution",
          "type": "select",
          "options": [
            { "value": "512", "label": "512³ (fastest)" },
            { "value": "1024", "label": "1024³" },
            { "value": "1024_cascade", "label": "1024³ Cascade (recommended)" },
            { "value": "1536_cascade", "label": "1536³ Cascade (slow)" }
          ],
          "default": "1024_cascade",
          "tooltip": "Voxel resolution. Higher = more detail but more VRAM and time."
        },
        {
          "id": "sparse_steps",
          "label": "Sparse Structure Steps",
          "type": "int",
          "default": 12,
          "min": 1,
          "max": 50
        },
        {
          "id": "shape_steps",
          "label": "Shape Steps",
          "type": "int",
          "default": 12,
          "min": 1,
          "max": 50
        },
        {
          "id": "tex_steps",
          "label": "Texture Steps",
          "type": "int",
          "default": 12,
          "min": 1,
          "max": 50
        },
        {
          "id": "faces",
          "label": "Max Faces",
          "type": "int",
          "default": -1,
          "min": -1,
          "max": 16777216
        },
        {
          "id": "texture_size",
          "label": "Texture Size",
          "type": "select",
          "options": [
            { "value": 2048, "label": "2048" },
            { "value": 4096, "label": "4096" },
            { "value": 8192, "label": "8192" }
          ],
          "default": 4096
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "int",
          "default": 42,
          "min": 0,
          "max": 2147483647
        }
      ]
    }
  ],

  "models": [
    {
      "id": "trellis-2-4b",
